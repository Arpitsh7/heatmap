// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(uuid())
  email String @unique
  provider AuthProvider
  name String
  supabaseId String @unique
  Platform Platform[]
  createdAt DateTime @default(now())
  Activities Activity[]

}
enum AuthProvider{ 
  Google
}

model Platform{
  PId String @id @default(uuid())
  userId String 
  user User @relation(fields:[userId],references:[id],onDelete:Cascade)
  Pname String 
  Purl String 
  meta types
  isConnected Boolean @default(false)
  createdAt DateTime @default(now())
  activities  Activity[]
}
enum types{
  auto
  manual
}
model Activity{
  id String @id @default(uuid())
  userId String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ActTypes ActType
  Count CountStats
  value Int
  metadata Json?
  date DateTime
  platformId String
  platform Platform @relation(fields:[platformId], references:[PId])
}
enum ActType{
  developement
  problems
}
enum CountStats{
  passive
  agressive
  max_aggressive
}
